# Copy to `.env` and fill in. All keys are prefixed with TAAKKUD_.

# Anthropic API key (used in phase 2 law digitization and phase 5 report generation)
TAAKKUD_ANTHROPIC_API_KEY=

# Optional overrides (defaults shown)
# TAAKKUD_ANTHROPIC_MODEL=claude-opus-4-8
# TAAKKUD_EMBEDDING_MODEL=intfloat/multilingual-e5-small
# TAAKKUD_TOP_K=5
# TAAKKUD_VERBATIM_MATCH_THRESHOLD=90
